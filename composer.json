{
    "name": "rubricate/uri",
    "description": "A lightweight and expressive URI parser and router component with regex placeholder support for modern MVC architectures.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Estefanio N Santos",
            "email": "estefanions@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "rubricate/filter": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "keywords": [
        "uri", "router", "mvc", "url-parser", "placeholders", "rubricate"
    ],
    "support": {
        "docs": "https://rubricate.github.io/components/uri",
        "source": "https://github.com/rubricate/uri",
        "issues": "https://github.com/rubricate/uri/issues"
    },
    "autoload": {
        "psr-4": {
            "Rubricate\\Uri\\": "Rubricate/Uri/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    }
}

